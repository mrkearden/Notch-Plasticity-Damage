@DSL Implicit;
@Behaviour UserDefinedViscoplasticity;

@StrainMeasure Hencky;

@Algorithm NewtonRaphson;
@Epsilon 1.e-14;
@Theta 1;

@Brick StandardElastoViscoPlasticity{
  stress_potential : "Hooke" {young_modulus : 210000.0, poisson_ratio : 0.3},
  inelastic_flow : "Plastic" {
    criterion : "Mises",
    isotropic_hardening : "Data" {
      values : {0.0 : 0.0, 0.0002 : 200.0, 1.0 : 210.0},
      interpolation : "linear"
    }
  }
};


